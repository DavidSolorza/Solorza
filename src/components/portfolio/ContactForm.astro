---
import { Icon } from "astro-icon/components";
import Heading from "../ui/Heading.astro";
import { getCollection } from "astro:content";
import { t } from "../../utils/i18n";

const [staticData] = await getCollection("staticData");
const lang = "es"; // Default, updated client-side
---

<section class="scroll-m-20 py-16 px-8 max-md:py-8" id="contact-form">
  <div class="mx-auto max-w-4xl">
    <!-- Header de la sección -->
    <div class="flex gap-4 items-center justify-center mb-12">
      <Icon class="text-3xl dark:text-white text-blacktext" name="envelope" />
      <Heading text={t("contact.title", lang)} textGradient={t("contact.titleGradient", lang)} level={2} />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Información de contacto -->
      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold text-blacktext dark:text-white mb-4" data-i18n="contact.workTogether">
            {t("contact.workTogether", lang)}
          </h3>
          <p
            class="text-lg text-blacktext/80 dark:text-gray-300 leading-relaxed"
            data-i18n="contact.description"
          >
            {t("contact.description", lang)}
          </p>
        </div>

        <!-- Métodos de contacto -->
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-accent-100 dark:bg-accent-900 rounded-full">
              <Icon
                name="envelope"
                class="size-6 text-accent-700 dark:text-accent-400"
              />
            </div>
            <div>
              <h4 class="font-semibold text-blacktext dark:text-white" data-i18n="contact.email">
                {t("contact.email", lang)}
              </h4>
              <a
                href={`mailto:${staticData.data.email}`}
                class="text-accent-700 dark:text-accent-400 hover:text-accent-800 dark:hover:text-accent-300 transition-colors"
              >
                {staticData.data.email}
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="p-3 bg-accent-100 dark:bg-accent-900 rounded-full">
              <Icon
                name="linkedin"
                class="size-6 text-accent-700 dark:text-accent-400"
              />
            </div>
            <div>
              <h4 class="font-semibold text-blacktext dark:text-white" data-i18n="contact.linkedin">
                {t("contact.linkedin", lang)}
              </h4>
              <a
                href={staticData.data.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-700 dark:text-accent-400 hover:text-accent-800 dark:hover:text-accent-300 transition-colors"
                data-i18n="contact.connectLinkedIn"
              >
                {t("contact.connectLinkedIn", lang)}
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="p-3 bg-accent-100 dark:bg-accent-900 rounded-full">
              <Icon
                name="github"
                class="size-6 text-accent-700 dark:text-accent-400"
              />
            </div>
            <div>
              <h4 class="font-semibold text-blacktext dark:text-white" data-i18n="contact.github">
                {t("contact.github", lang)}
              </h4>
              <a
                href={staticData.data.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-700 dark:text-accent-400 hover:text-accent-800 dark:hover:text-accent-300 transition-colors"
                data-i18n="contact.viewProjects"
              >
                {t("contact.viewProjects", lang)}
              </a>
            </div>
          </div>
        </div>

        <!-- Disponibilidad -->
        <div
          class="p-6 bg-accent-50 dark:bg-accent-950/30 rounded-xl border border-accent-200 dark:border-accent-800"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
            <span class="font-semibold text-blacktext dark:text-white" data-i18n="contact.available">
              {t("contact.available", lang)}
            </span>
          </div>
          <p class="text-sm text-blacktext/70 dark:text-gray-400" data-i18n="contact.responseTime">
            {t("contact.responseTime", lang)}
          </p>
        </div>
      </div>

      <!-- Formulario de contacto -->
      <div
        class="bg-white dark:bg-gray-900/50 rounded-2xl p-8 border border-gray-200 dark:border-gray-800 shadow-lg"
      >
        <form id="contact-form" class="space-y-5" novalidate>
          <div class="field-group">
            <label
              for="name"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.name"
            >
              {t("contact.form.name", lang)} *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.namePlaceholder", lang)}
              data-i18n-placeholder="contact.form.namePlaceholder"
            />
            <p class="text-xs text-red-500 mt-1 hidden" data-error="name"></p>
          </div>

          <div class="field-group">
            <label
              for="email"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.email"
            >
              {t("contact.form.email", lang)} *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.emailPlaceholder", lang)}
              data-i18n-placeholder="contact.form.emailPlaceholder"
            />
            <p class="text-xs text-red-500 mt-1 hidden" data-error="email"></p>
          </div>

          <div class="field-group">
            <label
              for="subject"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.subject"
            >
              {t("contact.form.subject", lang)} *
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.subjectPlaceholder", lang)}
              data-i18n-placeholder="contact.form.subjectPlaceholder"
            />
            <p class="text-xs text-red-500 mt-1 hidden" data-error="subject"></p>
          </div>

          <div class="field-group">
            <label
              for="message"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.message"
            >
              {t("contact.form.message", lang)} *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors resize-vertical invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.messagePlaceholder", lang)}
              data-i18n-placeholder="contact.form.messagePlaceholder"></textarea>
            <p class="text-xs text-red-500 mt-1 hidden" data-error="message"></p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-accent-600 hover:bg-accent-700 dark:bg-accent-700 dark:hover:bg-accent-800 text-white font-medium py-2.5 px-6 rounded-lg transition-all flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed shadow-md hover:shadow-lg active:scale-[0.98]"
          >
            <svg id="btn-spinner" class="size-5 hidden animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <Icon id="btn-icon" name="paperplane" class="size-5" />
            <span id="submit-text" data-i18n="contact.form.send">{t("contact.form.send", lang)}</span>
          </button>

          <div id="form-status" class="hidden items-center gap-3 p-4 rounded-lg text-sm border"></div>
        </form>
      </div>
    </div>
  </div>
</section>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("submit-btn");
    const submitText = document.getElementById("submit-text");
    const btnIcon = document.getElementById("btn-icon");
    const btnSpinner = document.getElementById("btn-spinner");
    const formStatus = document.getElementById("form-status");

    const fields = {
      name: { el: document.getElementById("name"), error: document.querySelector('[data-error="name"]') },
      email: { el: document.getElementById("email"), error: document.querySelector('[data-error="email"]') },
      subject: { el: document.getElementById("subject"), error: document.querySelector('[data-error="subject"]') },
      message: { el: document.getElementById("message"), error: document.querySelector('[data-error="message"]') },
    };

    const validators = {
      name: (v) => v.trim().length < 2 ? getText("nameError") : "",
      email: (v) => !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? getText("emailError") : "",
      subject: (v) => v.trim().length < 3 ? getText("subjectError") : "",
      message: (v) => v.trim().length < 10 ? getText("messageError") : "",
    };

    function getText(key) {
      const lang = localStorage.getItem("language") || "es";
      const texts = {
        es: { nameError: "El nombre debe tener al menos 2 caracteres", emailError: "Ingresa un email válido", subjectError: "El asunto debe tener al menos 3 caracteres", messageError: "El mensaje debe tener al menos 10 caracteres", sending: "Enviando...", send: "Enviar mensaje", successTitle: "Mensaje enviado", successMsg: "Gracias por contactarme. Te responderé a la brevedad.", errorTitle: "Error al enviar", errorMsg: "Ocurrió un error. Intenta de nuevo más tarde.", dismiss: "Cerrar" },
        en: { nameError: "Name must be at least 2 characters", emailError: "Enter a valid email", subjectError: "Subject must be at least 3 characters", messageError: "Message must be at least 10 characters", sending: "Sending...", send: "Send message", successTitle: "Message sent", successMsg: "Thank you for reaching out. I'll get back to you soon.", errorTitle: "Send error", errorMsg: "An error occurred. Please try again later.", dismiss: "Close" },
      };
      return texts[lang]?.[key] || key;
    }

    function validateField(name) {
      const field = fields[name];
      const error = validators[name](field.el.value);
      field.el.classList.toggle("border-red-400", !!error);
      field.el.classList.toggle("border-gray-300", !error);
      field.el.classList.toggle("dark:border-gray-700", !error);
      field.error.textContent = error;
      field.error.classList.toggle("hidden", !error);
      return !error;
    }

    Object.keys(fields).forEach((name) => {
      const field = fields[name];
      field.el.addEventListener("blur", () => validateField(name));
      field.el.addEventListener("input", () => {
        if (field.el.classList.contains("border-red-400")) validateField(name);
      });
    });

    function validateAll() {
      return Object.keys(fields).every(validateField);
    }

    function showStatus(type, title, msg) {
      const isSuccess = type === "success";
      formStatus.innerHTML = `
        <div class="flex items-center gap-3 w-full">
          <span class="text-lg shrink-0">${isSuccess ? "✅" : "❌"}</span>
          <div class="flex-1 min-w-0">
            <p class="font-medium">${title}</p>
            <p class="text-xs opacity-80 mt-0.5">${msg}</p>
          </div>
          <button type="button" class="shrink-0 text-lg leading-none opacity-60 hover:opacity-100 transition-opacity" id="status-close">&times;</button>
        </div>`;
      formStatus.className = `flex items-center gap-3 p-4 rounded-lg text-sm border ${
        isSuccess
          ? "bg-green-50 dark:bg-green-950/30 text-green-800 dark:text-green-300 border-green-200 dark:border-green-800"
          : "bg-red-50 dark:bg-red-950/30 text-red-800 dark:text-red-300 border-red-200 dark:border-red-800"
      }`;
      formStatus.classList.remove("hidden");
      document.getElementById("status-close")?.addEventListener("click", () => formStatus.classList.add("hidden"));
    }

    emailjs.init("lqo_OcD3fpGXsS3PB");

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      formStatus.classList.add("hidden");
      if (!validateAll()) return;

      submitBtn.disabled = true;
      btnIcon.classList.add("hidden");
      btnSpinner.classList.remove("hidden");
      const lang = localStorage.getItem("language") || "es";
      submitText.textContent = getText("sending");

      emailjs.sendForm("service_0uqj7ws", "template_3j9xfp8", form)
        .then(() => {
          form.reset();
          showStatus("success", getText("successTitle"), getText("successMsg"));
        })
        .catch((error) => {
          console.error("EmailJS Error:", error);
          showStatus("error", getText("errorTitle"), getText("errorMsg"));
        })
        .finally(() => {
          submitBtn.disabled = false;
          btnSpinner.classList.add("hidden");
          btnIcon.classList.remove("hidden");
          submitText.textContent = getText("send");
        });
    });
  });
</script>


