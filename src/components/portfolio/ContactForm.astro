---
import { Icon } from "astro-icon/components";
import Heading from "../ui/Heading.astro";
import { getCollection } from "astro:content";
import { t } from "../../utils/i18n";

const [staticData] = await getCollection("staticData");
const lang = "es"; // Default, updated client-side
---

<section class="scroll-m-20 py-16 px-8 max-md:py-8" id="contact-form">
  <div class="mx-auto max-w-4xl">
    <!-- Header de la sección -->
    <div class="flex gap-4 items-center justify-center mb-12">
      <Icon class="text-3xl dark:text-white text-blacktext" name="envelope" />
      <Heading text={t("contact.title", lang)} textGradient={t("contact.titleGradient", lang)} level={2} />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Información de contacto -->
      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold text-blacktext dark:text-white mb-4" data-i18n="contact.workTogether">
            {t("contact.workTogether", lang)}
          </h3>
          <p
            class="text-lg text-blacktext/80 dark:text-gray-300 leading-relaxed"
            data-i18n="contact.description"
          >
            {t("contact.description", lang)}
          </p>
        </div>

        <!-- Métodos de contacto -->
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full">
              <svg class="size-6 text-green-700 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-blacktext dark:text-white">WhatsApp</h4>
              <a
                href="https://wa.me/573137374108"
                target="_blank"
                rel="noopener noreferrer"
                class="text-green-700 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 transition-colors"
              >
                +57 313 737 4108
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="p-3 bg-accent-100 dark:bg-accent-900 rounded-full">
              <Icon
                name="linkedin"
                class="size-6 text-accent-700 dark:text-accent-400"
              />
            </div>
            <div>
              <h4 class="font-semibold text-blacktext dark:text-white" data-i18n="contact.linkedin">
                {t("contact.linkedin", lang)}
              </h4>
              <a
                href={staticData.data.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-700 dark:text-accent-400 hover:text-accent-800 dark:hover:text-accent-300 transition-colors"
                data-i18n="contact.connectLinkedIn"
              >
                {t("contact.connectLinkedIn", lang)}
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="p-3 bg-accent-100 dark:bg-accent-900 rounded-full">
              <Icon
                name="github"
                class="size-6 text-accent-700 dark:text-accent-400"
              />
            </div>
            <div>
              <h4 class="font-semibold text-blacktext dark:text-white" data-i18n="contact.github">
                {t("contact.github", lang)}
              </h4>
              <a
                href={staticData.data.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-700 dark:text-accent-400 hover:text-accent-800 dark:hover:text-accent-300 transition-colors"
                data-i18n="contact.viewProjects"
              >
                {t("contact.viewProjects", lang)}
              </a>
            </div>
          </div>
        </div>

        <!-- Disponibilidad -->
        <div
          class="p-6 bg-accent-50 dark:bg-accent-950/30 rounded-xl border border-accent-200 dark:border-accent-800"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
            <span class="font-semibold text-blacktext dark:text-white" data-i18n="contact.available">
              {t("contact.available", lang)}
            </span>
          </div>
          <p class="text-sm text-blacktext/70 dark:text-gray-400" data-i18n="contact.responseTime">
            {t("contact.responseTime", lang)}
          </p>
        </div>
      </div>

      <!-- Formulario de contacto -->
      <div
        class="bg-white dark:bg-gray-900/50 rounded-2xl p-8 border border-gray-200 dark:border-gray-800 shadow-lg"
      >
        <form id="contact-form" class="space-y-5" novalidate>
          <div class="field-group">
            <label
              for="name"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.name"
            >
              {t("contact.form.name", lang)} *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.namePlaceholder", lang)}
              data-i18n-placeholder="contact.form.namePlaceholder"
            />
            <p class="text-xs text-red-500 mt-1 hidden" data-error="name"></p>
          </div>

          <div class="field-group">
            <label
              for="email"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.email"
            >
              {t("contact.form.email", lang)} *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.emailPlaceholder", lang)}
              data-i18n-placeholder="contact.form.emailPlaceholder"
            />
            <p class="text-xs text-red-500 mt-1 hidden" data-error="email"></p>
          </div>

          <div class="field-group">
            <label
              for="subject"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.subject"
            >
              {t("contact.form.subject", lang)} *
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.subjectPlaceholder", lang)}
              data-i18n-placeholder="contact.form.subjectPlaceholder"
            />
            <p class="text-xs text-red-500 mt-1 hidden" data-error="subject"></p>
          </div>

          <div class="field-group">
            <label
              for="message"
              class="block text-sm font-medium text-blacktext dark:text-white mb-1.5"
              data-i18n="contact.form.message"
            >
              {t("contact.form.message", lang)} *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="4"
              class="w-full px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-blacktext dark:text-white focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-colors resize-vertical invalid:[&:not(:placeholder-shown)]:border-red-400"
              placeholder={t("contact.form.messagePlaceholder", lang)}
              data-i18n-placeholder="contact.form.messagePlaceholder"></textarea>
            <p class="text-xs text-red-500 mt-1 hidden" data-error="message"></p>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-green-600 hover:bg-green-700 text-white font-medium py-2.5 px-6 rounded-lg transition-all flex items-center justify-center gap-2 shadow-md hover:shadow-lg active:scale-[0.98]"
          >
            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span data-i18n="contact.form.send">{t("contact.form.send", lang)}</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("contact-form");
    const WHATSAPP_NUMBER = "573137374108";

    const fields = {
      name: { el: document.getElementById("name"), error: document.querySelector('[data-error="name"]') },
      email: { el: document.getElementById("email"), error: document.querySelector('[data-error="email"]') },
      subject: { el: document.getElementById("subject"), error: document.querySelector('[data-error="subject"]') },
      message: { el: document.getElementById("message"), error: document.querySelector('[data-error="message"]') },
    };

    const lang = () => localStorage.getItem("language") || "es";
    const t = (k) => ({ es: { nameError: "El nombre debe tener al menos 2 caracteres", emailError: "Ingresa un email válido", subjectError: "El asunto debe tener al menos 3 caracteres", messageError: "El mensaje debe tener al menos 10 caracteres" }, en: { nameError: "Name must be at least 2 characters", emailError: "Enter a valid email", subjectError: "Subject must be at least 3 characters", messageError: "Message must be at least 10 characters" } })[lang()][k];

    const validators = {
      name: (v) => v.trim().length < 2 ? t("nameError") : "",
      email: (v) => !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? t("emailError") : "",
      subject: (v) => v.trim().length < 3 ? t("subjectError") : "",
      message: (v) => v.trim().length < 10 ? t("messageError") : "",
    };

    function validateField(name) {
      const field = fields[name];
      const error = validators[name](field.el.value);
      field.el.classList.toggle("border-red-400", !!error);
      field.error.textContent = error;
      field.error.classList.toggle("hidden", !error);
      return !error;
    }

    Object.keys(fields).forEach((name) => {
      fields[name].el.addEventListener("blur", () => validateField(name));
      fields[name].el.addEventListener("input", function () {
        if (this.classList.contains("border-red-400")) validateField(name);
      });
    });

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const valid = Object.keys(fields).every(validateField);
      if (!valid) return;

      const name = fields.name.el.value.trim();
      const email = fields.email.el.value.trim();
      const subject = fields.subject.el.value.trim();
      const message = fields.message.el.value.trim();

      const text = `*${subject}*%0A%0A${message}%0A%0A---%0A${name}%0A${email}`;
      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${text}`, "_blank");
    });
  });
</script>


