---
import Button from "../ui/Button.astro";
import { t } from "../../utils/i18n";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const lang = "es";

const techStack = [
  "html", "javascript", "ts", "angular", "astro", "node",
  "tailwind", "mongo", "python", "git",
];
const techNames: Record<string, string> = {
  html: "HTML5", javascript: "JS", ts: "TS", angular: "Angular", astro: "Astro",
  node: "Node", tailwind: "Tailwind", mongo: "MongoDB", python: "Python", git: "Git",
};
---

<section class="scroll-m-20 px-8 max-sm:px-4 py-16 max-md:py-12" id="home">
  <div class="mx-auto max-w-7xl">
    <div class="rounded-3xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden">
      <div class="flex items-center justify-center gap-12 p-12 max-md:flex-col max-md:p-8 max-md:gap-8">
        <div class="size-56 max-md:size-36 shrink-0 reveal">
          <div class="size-full rounded-full bg-gray-100 dark:bg-gray-800 p-1 ring-4 ring-gray-100 dark:ring-gray-800">
            <a
              href={staticData.data.profileLink}
              class="block size-full rounded-full bg-center bg-cover transition-transform hover:scale-[1.02]"
              style={`background-image: url(${staticData.data.profileImage})`}
              aria-label={t("hero.aboutMe", lang)}
            />
          </div>
        </div>

        <div class="flex-1 max-w-xl reveal reveal-delay-1">
          <span class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-400 mb-4">
            <span class="size-2 rounded-full bg-green-400 shadow-[0_0_0_3px_rgba(34,197,94,0.3)] animate-pulse"></span>
            <span data-i18n="hero.available">{t("hero.available", lang)}</span>
          </span>

          <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-2 max-md:text-3xl">
            {staticData.data.profileName}
          </h1>
          <p class="text-xl font-medium text-accent-600 dark:text-accent-400 mb-4">
            {staticData.data.profileTitle}
          </p>
          <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
            <span data-i18n="hero.tagline">{t("hero.tagline", lang)}</span>
          </p>

          <div class="flex flex-wrap gap-3">
            <Button link="/#projects" text={t("hero.viewProjects", lang)} iconName="code" variant="dark" />
            <Button link="/#contact" text={t("hero.contactMe", lang)} iconName="envelope" variant="default" />
            <Button
              link={staticData.data.resumeUrl || "#"}
              text={t("hero.downloadCV", lang)}
              iconName="rocket"
              variant="default"
              isExternal={true}
            />
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-800">
        <div class="bg-white dark:bg-gray-900 p-8 max-md:p-6 reveal reveal-delay-2">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
            <span data-i18n="tech.stack">{t("tech.stack", lang)}</span>
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              techStack.map((tool) => (
                <span class="px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded-lg">
                  {techNames[tool] || tool}
                </span>
              ))
            }
          </div>
        </div>

        <div class="bg-white dark:bg-gray-900 p-8 max-md:p-6 reveal reveal-delay-3 border-t md:border-t-0 md:border-l border-gray-200 dark:border-gray-800">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
            {t("hobbies.title", lang)} {t("hobbies.titleGradient", lang)}
          </h3>
          <div class="flex flex-wrap gap-2">
            {
              staticData.data.hobbies.map((h) => (
                <span class="px-3 py-1.5 text-sm text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded-lg">{h}</span>
              ))
            }
          </div>
        </div>

        <div class="bg-white dark:bg-gray-900 p-8 max-md:p-6 reveal reveal-delay-4 border-t md:border-t-0 md:border-l border-gray-200 dark:border-gray-800">
          <a href={staticData.data.github} target="_blank" rel="noopener noreferrer" class="block group h-full">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4 group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">
              GitHub
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed" data-i18n="github.description">
              {t("github.description", lang)}
            </p>
            <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-accent-600 dark:text-accent-400 group-hover:gap-2 transition-all">
              @DavidSolorza <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
