---
import Button from "../ui/Button.astro";
import { t } from "../../utils/i18n";
import { getCollection } from "astro:content";

const [staticData] = await getCollection('staticData');
const lang = "es";
---

<section class="scroll-m-20 px-8 max-sm:px-4 py-16" id="home">
  <div class="mx-auto max-w-7xl rounded-3xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 shadow-sm">
    <div class="flex items-center justify-center gap-12 p-12 max-md:flex-col max-md:p-8 max-md:gap-8">
      
      <div class="size-56 max-md:size-36 shrink-0 reveal">
        <div class="size-full rounded-full bg-gray-100 dark:bg-gray-800 p-1">
          <div class="size-full rounded-full bg-center bg-cover" style={"background-image: url(" + staticData.data.profileImage + ")"}>
            <a href={staticData.data.profileLink} class="flex size-full rounded-full"></a>
          </div>
        </div>
      </div>

      <div class="flex-1 max-w-xl reveal reveal-delay-1">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-400 mb-4">
          <span class="size-2 rounded-full bg-green-400 shadow-[0_0_0_3px_rgba(34,197,94,0.3)]"></span>
          <span data-i18n="hero.available">{t("hero.available", lang)}</span>
        </span>

        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-3 max-md:text-3xl">
          {staticData.data.profileName}
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-8">
          <span class="font-semibold text-gray-900 dark:text-white">{staticData.data.profileTitle}</span>
          <span data-i18n="hero.experience">{t("hero.experience", lang)}</span>, <span data-i18n="hero.description">{t("hero.description", lang)}</span>
        </p>

        <div class="flex gap-3 max-sm:flex-col max-sm:items-start">
          <Button link="/#projects" text={t("hero.viewProjects", lang)} iconName="code" variant="dark" />
          <Button link={staticData.data.resumeUrl || "#"} text={t("hero.downloadCV", lang)} iconName="rocket" variant="default" isExternal={true} />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200 dark:bg-gray-800 rounded-b-3xl overflow-hidden">

      <div class="bg-white dark:bg-gray-900 p-8 max-md:p-6 reveal reveal-delay-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="size-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-500 dark:text-gray-400">
            <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Tech <span class="text-gray-500 dark:text-gray-400">{t("tech.stack", lang)}</span></h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {["html", "javascript", "ts", "angular", "astro", "node", "css", "tailwind", "bootstrap", "mongo", "firebase", "netlify", "git", "python"].map(tool => {
            const names = {html:"HTML5",javascript:"JS",ts:"TS",angular:"Angular",astro:"Astro",node:"Node",css:"CSS",tailwind:"Tailwind",bootstrap:"Bootstrap",mongo:"MongoDB",firebase:"Firebase",netlify:"Netlify",git:"Git",python:"Python"};
            return <span class="px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded-lg">{names[tool] || tool}</span>;
          })}
        </div>
      </div>

      <div class="bg-white dark:bg-gray-900 p-8 max-md:p-6 reveal reveal-delay-3 border-t md:border-t-0 md:border-l border-gray-200 dark:border-gray-800">
        <div class="flex items-center gap-3 mb-6">
          <div class="size-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-500 dark:text-gray-400">
            <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t("hobbies.title", lang)} <span class="text-gray-500 dark:text-gray-400">{t("hobbies.titleGradient", lang)}</span></h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {["Código abierto","Lectura","Café","Música","Cine","Running","Gaming"].map(h => <span class="px-3 py-1.5 text-sm text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded-lg">{h}</span>)}
        </div>
      </div>

      <div class="bg-white dark:bg-gray-900 p-8 max-md:p-6 reveal reveal-delay-4 border-t md:border-t-0 md:border-l border-gray-200 dark:border-gray-800">
        <a href={staticData.data.github} target="_blank" class="block">
          <div class="flex items-center gap-3 mb-4">
            <div class="size-10 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-gray-500 dark:text-gray-400">
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">GitHub</h3>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400">{t("github.description", lang)}</p>
        </a>
      </div>

    </div>
  </div>
</section>
