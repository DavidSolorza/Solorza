---
import ProjectCard from "./ProjectCard.astro";
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";
import { t } from "../../utils/i18n";
import { projects } from "../../data/projects";

const lang = "es";
---

<section
  class="scroll-m-20 py-16 px-8 max-md:py-12"
  id="projects"
  aria-label="Proyectos"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex gap-4 items-center justify-center mb-4">
      <Icon class="text-3xl dark:text-white text-blacktext" name="code" />
      <Heading
        text={t("projects.title", lang)}
        textGradient={t("projects.titleGradient", lang)}
        level={2}
        data-i18n-text="projects.title"
        data-i18n-gradient="projects.titleGradient"
      />
    </div>

    <p
      class="text-center text-lg text-blacktext/80 dark:text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed"
      data-i18n="projects.description"
    >
      {t("projects.description", lang)}
    </p>

    <div
      class="flex flex-wrap justify-center gap-2 mb-8"
      role="tablist"
      aria-label="Filtrar proyectos"
    >
      <button
        type="button"
        class="project-filter active px-4 py-2 text-sm font-medium rounded-full border transition-all"
        data-filter="all"
        role="tab"
        aria-selected="true"
        data-i18n="projects.filterAll"
      >
        {t("projects.filterAll", lang)}
      </button>
      <button
        type="button"
        class="project-filter px-4 py-2 text-sm font-medium rounded-full border transition-all"
        data-filter="web"
        role="tab"
        aria-selected="false"
        data-i18n="projects.filterWeb"
      >
        {t("projects.filterWeb", lang)}
      </button>
      <button
        type="button"
        class="project-filter px-4 py-2 text-sm font-medium rounded-full border transition-all"
        data-filter="mobile"
        role="tab"
        aria-selected="false"
        data-i18n="projects.filterMobile"
      >
        {t("projects.filterMobile", lang)}
      </button>
    </div>

    <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <div class="project-item reveal" data-category={project.category}>
            <ProjectCard {...project} />
          </div>
        ))
      }
    </div>

    <p
      id="projects-empty"
      class="hidden text-center text-gray-500 dark:text-gray-400 py-12"
      data-i18n="projects.noResults"
    >
      {t("projects.noResults", lang)}
    </p>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filters = document.querySelectorAll(".project-filter");
    const items = document.querySelectorAll(".project-item");
    const emptyMsg = document.getElementById("projects-empty");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.getAttribute("data-filter");

        filters.forEach((b) => {
          const isActive = b === btn;
          b.classList.toggle("active", isActive);
          b.setAttribute("aria-selected", String(isActive));
        });

        let visible = 0;
        items.forEach((item) => {
          const category = item.getAttribute("data-category");
          const show = filter === "all" || category === filter;
          item.classList.toggle("hidden", !show);
          if (show) visible++;
        });

        emptyMsg?.classList.toggle("hidden", visible > 0);
      });
    });
  });
</script>
