---
import ProjectCard from "./ProjectCard.astro";
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";
import { t } from "../../utils/i18n";

// Default to Spanish, will be updated client-side
const lang = "es";

// Aquí defines tus proyectos
const projects = [
  {
    title: "Sabores del Monte",
    description:
      "Tienda online de mermeladas artesanales desarrollada con tecnologías modernas. Implementé un diseño responsivo y atractivo usando React y Tailwind CSS, con enfoque en experiencia de usuario, catálogo de productos dinámico y flujo de compra simple.",
    technologies: [ "node", "mongo", "tailwind", "javascript","html"],
    liveUrl: "https://saboresdelmonte.shop/",
    githubUrl: "https://github.com/DavidSolorza/Sabores-Del-Monte.git",
    featured: true,
  },
  {
    title: "STREAMING PLUS",
    description:
      "Plataforma de venta de películas y series en línea, construida con tecnologías actuales. Desarrollé una interfaz atractiva y completamente responsiva utilizando React y Tailwind CSS, priorizando una experiencia de usuario fluida.",
    technologies: ["node", "mongo", "tailwind", "javascript",],
    liveUrl: "https://streamingpluss.shop/",
    githubUrl: "https://github.com/DavidSolorza/STREAMINGPLUS.git",
  },

  {
    title: "Portfolio Website",
    description:
      "Sitio web de portfolio personal con diseño moderno, animaciones suaves y optimización SEO.",
    technologies: ["astro", "tailwind", "javascript"],
    liveUrl: "https://davidsolorza.dev",
    githubUrl: "https://github.com/DavidSolorza/Solorza.git",
  },
  {
    title: "Colombia",
    description:
      "Plataforma informativa sobre Colombia, destacando su cultura, turismo y datos relevantes del país.",
    technologies: ["node", "mongo", "tailwind", "javascript"],
    liveUrl: "https://colombia-three.vercel.app",
    githubUrl: "https://github.com/DavidSolorza/Colombia.git",
  },
  {
    title: "Automatizador de Correos",
    description:
      "Sistema de automatización y clasificación de correos electrónicos con integración Gmail API, motor de reglas personalizable, autenticación OAuth2 y dashboard analítico.",
    technologies: ["ts", "python", "tailwind", "javascript"],
    liveUrl: "https://automatizador-de-correos.vercel.app",
    githubUrl: "https://github.com/DavidSolorza/AutomatizadorDeCorreos.git",
  },
  {
    title: "Battery Guardian",
    description:
      "App Flutter para monitoreo inteligente de batería en Android. Dashboard en tiempo real, alertas configurables, historial de cargas en SQLite y analíticas con gráficas.",
    technologies: ["dart"],
    githubUrl: "https://github.com/DavidSolorza/BatteryGuardian.git",
  },
  {
    title: "Quantum Lab",
    description:
      "Laboratorio interactivo de computación cuántica con simulaciones 3D. Incluye esfera de Bloch, algoritmo de Deutsch-Jozsa, entrelazamiento cuántico y visualizaciones con Three.js.",
    technologies: ["ts", "javascript", "tailwind"],
    liveUrl: "https://quantum-lab-three.vercel.app",
    githubUrl: "https://github.com/DavidSolorza/Quantum-Lab.git",
  },
  {
    title: "Electro+ Lab",
    description:
      "Simulador de circuitos eléctricos interactivo con editor visual, simulación DC/transitoria en tiempo real, multímetro, osciloscopio y calculadora de ingeniería eléctrica.",
    technologies: ["ts", "python", "javascript", "tailwind"],
    liveUrl: "https://circuit-nine.vercel.app",
    githubUrl: "https://github.com/DavidSolorza/circuit.git",
  },
  {
    title: "PathForge AI",
    description:
      "Plataforma web para crear y seguir rutas de aprendizaje personalizadas con IA. Frontend React con backend Express y MongoDB, con soporte para modo local.",
    technologies: ["ts", "node", "mongo", "javascript", "tailwind"],
    liveUrl: "https://path-forge-nu.vercel.app",
    githubUrl: "https://github.com/DavidSolorza/PathForge.git",
  },
];
---

<section
  class="scroll-m-20 py-16 px-8 max-md:py-8"
  id="projects"
  aria-label="Proyectos destacados"
>
  <div class="mx-auto max-w-7xl">
    <!-- Header de la sección -->
    <div class="flex gap-4 items-center justify-center mb-12">
      <Icon class="text-3xl dark:text-white text-blacktext" name="code" />
      <Heading text={t("projects.title", lang)} textGradient={t("projects.titleGradient", lang)} level={2} />
    </div>

    <p
      class="text-center text-lg text-blacktext/80 dark:text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed"
      data-i18n="projects.description"
    >
      {t("projects.description", lang)}
    </p>

    <!-- Grid de proyectos -->
    <div
      class="flex flex-wrap justify-center gap-6"
    >
      {projects.map((project) => <div class="w-full sm:w-[calc(50%-12px)] xl:w-[calc(25%-18px)]"><ProjectCard {...project} /></div>)}
    </div>

    
  </div>
</section>
