---
import { t } from "../../utils/i18n";

interface Props {
  title: string;
  description: string;
  technologies: string[];
  liveUrl?: string;
  githubUrl?: string;
  category?: string;
}

const {
  title,
  description,
  technologies,
  liveUrl,
  githubUrl,
  category = "web",
} = Astro.props;

const techNames: Record<string, string> = {
  html: "HTML5",
  javascript: "JS",
  ts: "TS",
  angular: "Angular",
  astro: "Astro",
  node: "Node",
  css: "CSS",
  tailwind: "Tailwind",
  bootstrap: "Bootstrap",
  mongo: "MongoDB",
  firebase: "Firebase",
  netlify: "Netlify",
  git: "Git",
  python: "Python",
  dart: "Flutter",
};
---

<article
  class="project-card bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-6 transition-all hover:shadow-lg hover:border-gray-300 dark:hover:border-gray-600 h-full flex flex-col"
  data-category={category}
>
  <h3 class="text-lg font-semibold text-gray-900 dark:text-white leading-snug mb-3">{title}</h3>

  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4 flex-1">{description}</p>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {
      technologies.map((tech) => (
        <span class="px-2.5 py-1 text-xs font-medium text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 rounded-md">
          {techNames[tech] || tech}
        </span>
      ))
    }
  </div>

  <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-100 dark:border-gray-800 mt-auto">
    {
      liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm font-medium text-gray-900 dark:text-white hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
        >
          <span data-i18n="projects.viewProject">{t("projects.viewProject", "es")}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      )
    }
    {
      githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
        >
          <span data-i18n="projects.code">{t("projects.code", "es")}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      )
    }
  </div>
</article>
