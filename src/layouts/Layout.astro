---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

const {
  pageTitle = "David Solorza",
  description = "Modern, minimalist portfolio template crafted for developers and digital creatives.",
  ogimage = {
    url: "/images/imagedefault.webp",
    alt: "Default image of David Solorza portfolio",
  },
} = Astro.props;

const siteUrl = new URL(Astro.url).origin;
const SEO = {
  sitename: "David Solorza Portfolio",
  url: siteUrl,
  locale: "es_CO",
  author: "David Solorza",
  twitter: "@davidsolorza",
};

const twitterimage = `${siteUrl}${ogimage.url}`;
---

<html lang="es" class="dark:bg-gray-950 bg-gray-50 font-sans scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>

    <link rel="icon" href="/images/terminal.png" />

    <meta name="description" content={description} />
    <meta name="author" content={SEO.author} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`${Astro.site}${Astro.url.pathname}`} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogimage.url} />
    <meta property="og:image:alt" content={ogimage.alt} />
    <meta property="og:url" content={SEO.url} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SEO.sitename} />
    <meta property="og:locale" content={SEO.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={twitterimage} />
    <meta name="twitter:image:alt" content={ogimage.alt} />
    <meta name="twitter:site" content={SEO.twitter} />

    <meta name="theme-color" content="#0a0a0a" />

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="overflow-x-hidden antialiased">
    <div id="scroll-progress" aria-hidden="true"></div>
    <div class="blur-circle"></div>
    <div
      style="background:linear-gradient(45deg, rgba(148, 163, 184, 0) 10.79%, rgba(148, 163, 184, 0.02) 40.92%, rgba(148, 163, 184, 0) 90.35%)"
      class="fixed top-0 left-0 w-full h-full pointer-events-none -z-1"
    >
    </div>

    <Header />

    <main class="min-h-[85vh]">
      <slot />
    </main>

    <Footer />

    <button id="back-to-top" aria-label="Volver arriba" title="Volver arriba">
      <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
      </svg>
    </button>

    <script>
      import "../scripts/menu.js";
      import "../scripts/i18n.js";
    </script>
  </body>
</html>
