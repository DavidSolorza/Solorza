---
import Layout from "../layouts/Layout.astro";
import HeroProfile from "../components/portfolio/HeroProfile.astro";
import ExperienceSection from "../components/portfolio/ExperienceSection.astro";
import ProjectsGrid from "../components/portfolio/ProjectsGrid.astro";
import Contact from "../components/portfolio/Contact.astro";

const pageTitle = "David Solorza | Desarrollador Frontend";
const description = "Portafolio de David Solorza — desarrollador frontend especializado en apps web, automatización y proyectos full-stack. Disponible para freelance.";
const ogimage = {
  url: "/images/imagedefault.webp",
  alt: "Screenshot of a web portfolio with a modern and dark design. Featuring David Solorza, a Frontend Developer with experience in modern web technologies.",
};
---

<Layout pageTitle={pageTitle} description={description} ogimage={ogimage}>
  <HeroProfile />
  <ExperienceSection />
  <ProjectsGrid />
  <Contact />
</Layout>
